rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Security Net (Default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Global Helpers (Pillar 3 & 10)
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is the owner of the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verify if the user matches our master admin email
    function isAdmin() {
      return isSignedIn() && 
             ("email" in request.auth.token) &&
             (request.auth.token.email.lower() == "angeloperfecto31@gmail.com");
    }

    // Prevent ID poisoning
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints (Pillar 2: Validation Blueprints)
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 128
        && (!("isActive" in data) || data.isActive == null || data.isActive is bool)
        && (!("paymentStatus" in data) || data.paymentStatus == null || data.paymentStatus is string)
        && (!("bypassPayment" in data) || data.bypassPayment == null || data.bypassPayment is bool)
        && (!("activatedAt" in data) || data.activatedAt == null || data.activatedAt is string)
        && (!("pendingVerification" in data) || data.pendingVerification == null || (
             data.pendingVerification.senderName is string && data.pendingVerification.senderName.size() <= 128 &&
             data.pendingVerification.referenceNo is string && data.pendingVerification.referenceNo.size() <= 128 &&
             (data.pendingVerification.amount is int || data.pendingVerification.amount is float) &&
             data.pendingVerification.submittedAt is string
           ));
    }

    function isValidSettings(data) {
      return (!("qrCodeDataUrl" in data) || data.qrCodeDataUrl == null || (data.qrCodeDataUrl is string && data.qrCodeDataUrl.size() <= 1000000))
        && (!("basicPrice" in data) || data.basicPrice == null || (data.basicPrice is int || data.basicPrice is float))
        && (!("premiumPrice" in data) || data.premiumPrice == null || (data.premiumPrice is int || data.premiumPrice is float))
        && (!("upgradePrice" in data) || data.upgradePrice == null || (data.upgradePrice is int || data.upgradePrice is float))
        && (!("promoDiscountBasic" in data) || data.promoDiscountBasic == null || (data.promoDiscountBasic is int || data.promoDiscountBasic is float))
        && (!("promoDiscountPremium" in data) || data.promoDiscountPremium == null || (data.promoDiscountPremium is int || data.promoDiscountPremium is float))
        && (!("offerTitle" in data) || data.offerTitle == null || data.offerTitle is string)
        && (!("offerExpiry" in data) || data.offerExpiry == null || data.offerExpiry is string)
        && (!("updatedBy" in data) || data.updatedBy == null || data.updatedBy is string)
        && (!("updatedAt" in data) || data.updatedAt == null || data.updatedAt is string)
        && (!("enableMaribank" in data) || data.enableMaribank == null || data.enableMaribank is bool)
        && (!("enableGCash" in data) || data.enableGCash == null || data.enableGCash is bool)
        && (!("enablePayMongo" in data) || data.enablePayMongo == null || data.enablePayMongo is bool);
    }

    function isValidProject(data) {
      return data.keys().hasAll(["name", "lastModified", "data", "ownerId"])
        && data.keys().size() == 4
        && data.name is string && data.name.size() <= 300
        && (data.lastModified is int || data.lastModified is float)
        && data.data is map
        && data.ownerId is string && data.ownerId == request.auth.uid;
    }

    function isValidFixture(data) {
      return data.keys().hasAll(["id", "category", "lightType", "wattage", "lumens", "ownerId"])
        && data.id is string && data.id.size() <= 128
        && data.category is string && data.category.size() <= 128
        && data.lightType is string && data.lightType.size() <= 128
        && (data.wattage is int || data.wattage is float)
        && (data.lumens is int || data.lumens is float)
        && data.ownerId is string && data.ownerId == request.auth.uid
        && (!("brands" in data) || data.brands is string)
        && (!("wattageRange" in data) || data.wattageRange is string)
        && (!("lumensRange" in data) || data.lumensRange is string)
        && (!("description" in data) || data.description is string)
        && (!("manufacturer" in data) || data.manufacturer is string)
        && (!("modelNumber" in data) || data.modelNumber is string)
        && (!("importedAt" in data) || data.importedAt is string);
    }

    function isValidMotorFLC(data) {
      return data.keys().hasAll(["hp"])
        && data.hp is string && data.hp.size() <= 128
        && (!("v115" in data) || data.v115 == null || data.v115 is int || data.v115 is float)
        && (!("v200" in data) || data.v200 == null || data.v200 is int || data.v200 is float)
        && (!("v208" in data) || data.v208 == null || data.v208 is int || data.v208 is float)
        && (!("v230" in data) || data.v230 == null || data.v230 is int || data.v230 is float)
        && (!("v400" in data) || data.v400 == null || data.v400 is int || data.v400 is float)
        && (!("v460" in data) || data.v460 == null || data.v460 is int || data.v460 is float)
        && (!("v575" in data) || data.v575 == null || data.v575 is int || data.v575 is float)
        && (!("v2300" in data) || data.v2300 == null || data.v2300 is int || data.v2300 is float);
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(["invoiceNo", "userId", "userEmail", "totalAmount", "paymentStatus", "transactionDate"])
        && data.invoiceNo is string && data.invoiceNo.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userEmail is string && data.userEmail.size() <= 128
        && (data.totalAmount is int || data.totalAmount is float)
        && data.paymentStatus is string && data.paymentStatus.size() <= 64
        && data.transactionDate is string
        && (!("userName" in data) || data.userName is string)
        && (!("plan" in data) || data.plan is string)
        && (!("billingPeriod" in data) || data.billingPeriod is string)
        && (!("paymentMethod" in data) || data.paymentMethod is string)
        && (!("amountPaid" in data) || data.amountPaid is int || data.amountPaid is float)
        && (!("regPrice" in data) || data.regPrice is int || data.regPrice is float)
        && (!("taxes" in data) || data.taxes is int || data.taxes is float)
        && (!("discounts" in data) || data.discounts is int || data.discounts is float)
        && (!("fees" in data) || data.fees is int || data.fees is float)
        && (!("createdAt" in data) || data.createdAt is string)
        && (!("paymentReference" in data) || data.paymentReference is string);
    }

    // 3. User Collection Matched Rules (Pillar 4: Tiered Identity & Pillar 12: Immortal field)
    match /users/{userId} {
      // Safe list query (Pillar 8: Secure List Queries)
      // Only admins can inspect all users list or query it.
      // Individual users can read only their own documents.
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isValidId(userId) && (
        (isOwner(userId) && isValidUser(incoming()) && ("email" in request.auth.token) && incoming().email.lower() == request.auth.token.email.lower()) ||
        isAdmin()
      );

      allow update: if isValidId(userId) && (
        isAdmin() ||
        (
          isOwner(userId) && isValidUser(incoming()) &&
          (!("email" in existing()) || existing().email == null || incoming().email.lower() == existing().email.lower()) &&                                         // Email is immutable (case-insensitive)
          (
            // Action 1: Standard customer flow (no self-activation)
            (
              (!("isActive" in existing()) || existing().isActive == null || incoming().isActive == existing().isActive) &&
              (
                // Action 1a: Submit verifications
                (incoming().paymentStatus == "pending_verification" && incoming().pendingVerification != null) ||
                // Action 1b: Reset review process
                (incoming().paymentStatus == "unpaid" && (!("pendingVerification" in incoming()) || incoming().pendingVerification == null))
              )
            ) ||
            // Action 2: Login bypass activation for already registered users
            (
              incoming().isActive == true &&
              incoming().paymentStatus == "paid" &&
              incoming().bypassPayment == true
            )
          )
        )
      );

      // Users can delete their own account (for cancellation), or admins can
      allow delete: if isAdmin() || isOwner(userId);

      // 3.5 Projects Subcollection
      match /projects/{projectId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(projectId) && isValidProject(incoming());
        allow update: if isOwner(userId) && isValidId(projectId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastModified', 'data']) &&
          incoming().name is string && incoming().name.size() <= 300 &&
          (incoming().lastModified is int || incoming().lastModified is float) &&
          incoming().data is map;
        allow delete: if isOwner(userId) || isAdmin();
      }

      // 3.6 Imported Fixtures Subcollection (Automatic synchronization of imported fixture data with project database)
      match /importedFixtures/{fixtureId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(fixtureId) && isValidFixture(incoming());
        allow update: if isOwner(userId) && isValidId(fixtureId) && isValidFixture(incoming());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // 4. Settings Collection Matched Rules (Pillar 6: Isolated Config and Admin Control)
    match /settings/{settingId} {
      // All authenticated users can read settings
      allow read: if isSignedIn() && isValidId(settingId);

      // Only administrators can manipulate configurations
      allow create, update: if isAdmin() && isValidId(settingId) && isValidSettings(incoming());
      allow delete: if isAdmin() && isValidId(settingId);
    }

    // 5. Motor FLC Library Collection (Dynamic Table 4.30.14.4)
    match /motor_flc_library/{entryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(entryId) && isValidMotorFLC(incoming());
      allow delete: if isAdmin() && isValidId(entryId);
    }

    // 6. Admin Activity Logs
    match /admin_activity_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false; // Logs are append-only forever
    }

    // 7. System Invoices (ABAC Multi-tenant isolation)
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid && isValidInvoice(request.resource.data));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
