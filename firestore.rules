rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Security Net (Default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Global Helpers (Pillar 3 & 10)
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is the owner of the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verify if the user matches our master admin email
    function isAdmin() {
      return isSignedIn() && 
             ("email" in request.auth.token) &&
             (request.auth.token.email == "angeloperfecto31@gmail.com" || request.auth.token.email == "Angeloperfecto31@gmail.com");
    }

    // Prevent ID poisoning
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints (Pillar 2: Validation Blueprints)
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 128
        && (!("isActive" in data) || data.isActive == null || data.isActive is bool)
        && (!("paymentStatus" in data) || data.paymentStatus == null || data.paymentStatus is string)
        && (!("bypassPayment" in data) || data.bypassPayment == null || data.bypassPayment is bool)
        && (!("activatedAt" in data) || data.activatedAt == null || data.activatedAt is string)
        && (!("pendingVerification" in data) || data.pendingVerification == null || (
             data.pendingVerification.senderName is string && data.pendingVerification.senderName.size() <= 128 &&
             data.pendingVerification.referenceNo is string && data.pendingVerification.referenceNo.size() <= 128 &&
             data.pendingVerification.amount is number &&
             data.pendingVerification.submittedAt is string
           ));
    }

    function isValidSettings(data) {
      return (!("qrCodeDataUrl" in data) || data.qrCodeDataUrl == null || (data.qrCodeDataUrl is string && data.qrCodeDataUrl.size() <= 1000000))
        && (!("basicPrice" in data) || data.basicPrice == null || data.basicPrice is number)
        && (!("premiumPrice" in data) || data.premiumPrice == null || data.premiumPrice is number)
        && (!("upgradePrice" in data) || data.upgradePrice == null || data.upgradePrice is number)
        && (!("promoDiscountBasic" in data) || data.promoDiscountBasic == null || data.promoDiscountBasic is number)
        && (!("promoDiscountPremium" in data) || data.promoDiscountPremium == null || data.promoDiscountPremium is number)
        && (!("offerTitle" in data) || data.offerTitle == null || data.offerTitle is string)
        && (!("offerExpiry" in data) || data.offerExpiry == null || data.offerExpiry is string)
        && (!("updatedBy" in data) || data.updatedBy == null || data.updatedBy is string)
        && (!("updatedAt" in data) || data.updatedAt == null || data.updatedAt is string);
    }

    // 3. User Collection Matched Rules (Pillar 4: Tiered Identity & Pillar 12: Immortal field)
    match /users/{userId} {
      // Safe list query (Pillar 8: Secure List Queries)
      // Only admins can inspect all users list or query it.
      // Individual users can read only their own documents.
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isValidId(userId) && (
        (isOwner(userId) && isValidUser(incoming()) && ("email" in request.auth.token) && incoming().email.lower() == request.auth.token.email.lower()) ||
        isAdmin()
      );

      allow update: if isValidId(userId) && (
        isAdmin() ||
        (
          isOwner(userId) && isValidUser(incoming()) &&
          (!("email" in existing()) || existing().email == null || incoming().email.lower() == existing().email.lower()) &&                                         // Email is immutable (case-insensitive)
          (
            // Action 1: Standard customer flow (no self-activation)
            (
              (!("isActive" in existing()) || existing().isActive == null || incoming().isActive == existing().isActive) &&
              (
                // Action 1a: Submit verifications
                (incoming().paymentStatus == "pending_verification" && incoming().pendingVerification != null) ||
                // Action 1b: Reset review process
                (incoming().paymentStatus == "unpaid" && (!("pendingVerification" in incoming()) || incoming().pendingVerification == null))
              )
            ) ||
            // Action 2: Login bypass activation for already registered users
            (
              incoming().isActive == true &&
              incoming().paymentStatus == "paid" &&
              incoming().bypassPayment == true
            )
          )
        )
      );

      // Users can delete their own account (for cancellation), or admins can
      allow delete: if isAdmin() || isOwner(userId);
    }

    // 4. Settings Collection Matched Rules (Pillar 6: Isolated Config and Admin Control)
    match /settings/{settingId} {
      // All authenticated users can read settings
      allow read: if isSignedIn() && isValidId(settingId);

      // Only administrators can manipulate configurations
      allow create, update: if isAdmin() && isValidId(settingId) && isValidSettings(incoming());
      allow delete: if isAdmin() && isValidId(settingId);
    }
  }
}
