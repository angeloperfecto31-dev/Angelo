{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with activation and verification status",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The user's registered email address"
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the user has an active, paid account"
        },
        "paymentStatus": {
          "type": "string",
          "description": "The payment status of the user, e.g., unpaid, paid, pending_verification"
        },
        "bypassPayment": {
          "type": "boolean",
          "description": "True if user was activated via the login bypass"
        },
        "activatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was activated"
        },
        "pendingVerification": {
          "type": "object",
          "description": "Details of the GCash manual payment submission for review",
          "properties": {
            "senderName": {
              "type": "string"
            },
            "referenceNo": {
              "type": "string"
            },
            "amount": {
              "type": "number"
            },
            "submittedAt": {
              "type": "string"
            }
          }
        },
        "approvedBy": {
          "type": "string"
        },
        "approvedAt": {
          "type": "string"
        },
        "rejectedBy": {
          "type": "string"
        },
        "rejectedAt": {
          "type": "string"
        },
        "amount": {
          "type": "number",
          "description": "The exact subscription amount actually paid by the user"
        },
        "paymentSource": {
          "type": "string",
          "description": "GCash, MariBank, etc."
        },
        "paymentReference": {
          "type": "string",
          "description": "Validation transaction reference number"
        },
        "senderName": {
          "type": "string",
          "description": "Name of sender for manually submitted payments"
        },
        "plan": {
          "type": "string"
        },
        "plan_name": {
          "type": "string"
        },
        "subscription_type": {
          "type": "string"
        },
        "is_lifetime": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        },
        "upgraded_by_admin": {
          "type": "boolean"
        },
        "last_modified_by": {
          "type": "string"
        },
        "modified_at": {
          "type": "string"
        }
      },
      "required": [
        "email"
      ]
    },
    "Project": {
      "title": "Project",
      "description": "A saved project linked to a user account",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the saved project"
        },
        "lastModified": {
          "type": "number",
          "description": "Timestamp of the last modification"
        },
        "data": {
          "type": "object",
          "description": "The serialized project data"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this project"
        }
      },
      "required": [
        "name",
        "lastModified",
        "data",
        "ownerId"
      ]
    },
    "Fixture": {
      "title": "Fixture",
      "description": "Custom imported lighting fixture details",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique fixture identifier"
        },
        "category": {
          "type": "string",
          "description": "Indoor, Outdoor, or Special"
        },
        "lightType": {
          "type": "string",
          "description": "The name/type of light fixture"
        },
        "wattageRange": {
          "type": "string",
          "description": "The operating wattage range"
        },
        "lumensRange": {
          "type": "string",
          "description": "The lumen output range"
        },
        "brands": {
          "type": "string",
          "description": "Manufacturer name"
        },
        "wattage": {
          "type": "number",
          "description": "Default operating wattage"
        },
        "lumens": {
          "type": "number",
          "description": "Default lumen output"
        },
        "description": {
          "type": "string",
          "description": "Direct specification details"
        },
        "manufacturer": {
          "type": "string",
          "description": "Specific brand manufacturer"
        },
        "modelNumber": {
          "type": "string",
          "description": "Exact commercial model number"
        },
        "importedAt": {
          "type": "string",
          "description": "Timestamp of when it was imported to Firestore"
        },
        "ownerId": {
          "type": "string",
          "description": "Owner user ID"
        }
      },
      "required": [
        "id",
        "category",
        "lightType",
        "wattage",
        "lumens",
        "ownerId"
      ]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application configuration documents",
      "type": "object",
      "properties": {
        "qrCodeDataUrl": {
          "type": "string",
          "description": "The base64 encoded string representing the custom GCash payment QR code"
        },
        "basicPrice": {
          "type": "number",
          "description": "The dynamic price of the Basic Plan"
        },
        "premiumPrice": {
          "type": "number",
          "description": "The dynamic price of the Premium Plan"
        },
        "upgradePrice": {
          "type": "number",
          "description": "The dynamic price to upgrade from Basic to Premium"
        },
        "promoDiscountBasic": {
          "type": "number",
          "description": "Optional promotional discount for Basic Plan"
        },
        "promoDiscountPremium": {
          "type": "number",
          "description": "Optional promotional discount for Premium Plan"
        },
        "offerTitle": {
          "type": "string",
          "description": "The title of a promotional offer"
        },
        "offerExpiry": {
          "type": "string",
          "description": "ISO timestamp indicating when the promotional offer expires"
        },
        "updatedBy": {
          "type": "string",
          "description": "Email address of the admin who updated the setting"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO timestamp of the last update"
        }
      }
    },
    "MotorFLC": {
      "title": "MotorFLC",
      "description": "Full-Load Current values for Three-Phase motors",
      "type": "object",
      "properties": {
        "hp": {
          "type": "string"
        },
        "v115": {
          "type": "number"
        },
        "v200": {
          "type": "number"
        },
        "v208": {
          "type": "number"
        },
        "v230": {
          "type": "number"
        },
        "v400": {
          "type": "number"
        },
        "v460": {
          "type": "number"
        },
        "v575": {
          "type": "number"
        },
        "v2300": {
          "type": "number"
        }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice generated for successful subscription, purchase or payment template",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "plan": { "type": "string" },
        "billingPeriod": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "amountPaid": { "type": "number" },
        "regPrice": { "type": "number" },
        "taxes": { "type": "number" },
        "discounts": { "type": "number" },
        "fees": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "transactionDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "paymentReference": { "type": "string" }
      },
      "required": [
        "invoiceNo",
        "userId",
        "userEmail",
        "totalAmount",
        "paymentStatus",
        "transactionDate"
      ]
    },
    "SystemModule": {
      "title": "SystemModule",
      "description": "Module visibility and maintenance configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "hidden", "disabled", "maintenance"]
        },
        "maintenanceMessage": { "type": "string" },
        "expectedCompletion": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "ModuleAuditLog": {
      "title": "ModuleAuditLog",
      "description": "Audit trail for module status changes",
      "type": "object",
      "properties": {
        "adminName": { "type": "string" },
        "adminEmail": { "type": "string" },
        "moduleId": { "type": "string" },
        "moduleName": { "type": "string" },
        "previousStatus": { "type": "string" },
        "newStatus": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["adminEmail", "moduleId", "newStatus", "timestamp"]
    },
    "BlacklistedEmail": {
      "title": "BlacklistedEmail",
      "description": "Blacklisted emails that are banned/restricted from receiving a new free trial",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "blacklistedAt": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["email", "blacklistedAt"]
    }
  },
  "firestore": {
    "blacklisted_emails/{emailId}": {
      "schema": "BlacklistedEmail",
      "description": "Records of emails restricted from auto-provisioning free trials"
    },
    "modules/{moduleId}": {
      "schema": "SystemModule",
      "description": "Module state configurations"
    },
    "moduleAuditLogs/{logId}": {
      "schema": "ModuleAuditLog",
      "description": "Audit trail of module changes"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and payment records"
    },
    "users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "Saved projects owned by the user"
    },
    "users/{userId}/importedFixtures/{fixtureId}": {
      "schema": "Fixture",
      "description": "Imported or customized lighting fixtures stored securely by user"
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "Global environment settings"
    },
    "motor_flc_library/{entryId}": {
      "schema": "MotorFLC",
      "description": "Customized or standard Three-Phase motor full load current data library"
    },
    "invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "System-wide invoices for trackable sales and active financial flows"
    }
  }
}
